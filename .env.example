# ============================================
# Neuropod AI — environment configuration
# ============================================

# Core
NEUROPOD_DEMO_MODE=true
NEUROPOD_STORE_PATH=./data/demo_store.json
NEUROPOD_BASE_URL=http://localhost:8000
NEUROPOD_FRONTEND_URL=http://localhost:3000
NEUROPOD_DEFAULT_TOPICS=language models,retrieval augmented generation,robotics
NEUROPOD_DEFAULT_EPISODES=3

# How far back the ranker considers papers (in days). Drives the recency half-life and arXiv date filter.
NEUROPOD_DISCOVERY_WINDOW_DAYS=7

# Live arXiv discovery (set true to query the real API instead of the demo catalog)
NEUROPOD_LIVE_DISCOVERY=false

ENABLE_SCHEDULER=false
NEUROPOD_SCHEDULER_TIMEZONE=America/Los_Angeles

# ============================================
# AI providers — wire any/all to upgrade demo
# ============================================
# Anthropic — preferred for script generation if set
# https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# OpenAI — script generation (fallback), TTS, embeddings
# https://platform.openai.com/api-keys
OPENAI_API_KEY=
OPENAI_TTS_VOICE=alloy

# ElevenLabs — preferred TTS when set (more expressive than OpenAI)
# https://elevenlabs.io/app/settings/api-keys
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Provider routing (auto = use real if key present, demo otherwise)
NEUROPOD_LLM_PROVIDER=auto       # auto | anthropic | openai
NEUROPOD_TTS_PROVIDER=auto       # auto | elevenlabs | openai | demo
NEUROPOD_EMBEDDER=auto           # auto | demo

# Frontend
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
